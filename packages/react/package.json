{
  "name": "@nrshagor/devlens-react",
  "private": false,
  "version": "0.1.0",
  "description": "React adapter for DevLens.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nrshagor/devlens.git"
  },
  "homepage": "https://github.com/nrshagor/devlens",
  "bugs": {
    "url": "https://github.com/nrshagor/devlens/issues"
  },
  "keywords": [
    "react",
    "debugging",
    "devtools",
    "performance",
    "monitoring",
    "debugbar",
    "developer-tools",
    "frontend",
    "nrshagor",
    "devlens",
    "nrshagor"
  ],
  "scripts": {
    "dev": "tsup src/index.tsx --watch",
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint react\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@nrshagor/devlens-ui": "workspace:^",
    "@nrshagor/devlens-core": "workspace:^"
  }
}
