{
  "name": "@codenrs/devlens-react",
  "version": "0.0.0",
  "private": true,
  "description": "React adapter for DevLens.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.tsx --watch",
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint react\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@codenrs/devlens-ui": "workspace:*",
    "@codenrs/devlens-core": "workspace:*"
  }
}
