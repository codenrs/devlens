{
  "name": "@codenrs/devlens-core",
  "private": false,
  "version": "0.1.0-alpha.3",
  "description": "Core runtime engine for DevLens.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codenrs/devlens.git"
  },
  "homepage": "https://github.com/codenrs/devlens",
  "bugs": {
    "url": "https://github.com/codenrs/devlens/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "debugging",
    "devtools",
    "performance",
    "monitoring",
    "runtime",
    "frontend",
    "codenrs",
    "devlens",
    "nrshagor"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint core\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@codenrs/devlens-shared": "0.1.0-alpha.3"
  }
}
