{
  "name": "@codenrs/devlens-ui",
  "private": false,
  "version": "0.1.0-alpha.3",
  "description": "UI components for DevLens.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/devlens.css": "./dist/styles/devlens.css"
  },
  "sideEffects": [
    "./dist/styles/devlens.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codenrs/devlens.git"
  },
  "homepage": "https://github.com/codenrs/devlens",
  "bugs": {
    "url": "https://github.com/codenrs/devlens/issues"
  },
  "keywords": [
    "react",
    "ui",
    "debugging",
    "devtools",
    "developer-tools",
    "debugbar",
    "frontend",
    "codenrs",
    "devlens",
    "nrshagor"
  ],
  "scripts": {
    "dev": "tsup src/index.tsx --watch --publicDir src",
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --publicDir src",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint ui\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@codenrs/devlens-core": "workspace:^"
  }
}
