{
  "name": "@codenrs/devlens-next",
  "private": false,
  "version": "0.1.0-alpha.3",
  "description": "Next.js adapter for DevLens.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codenrs/devlens.git"
  },
  "homepage": "https://github.com/codenrs/devlens",
  "bugs": {
    "url": "https://github.com/codenrs/devlens/issues"
  },
  "keywords": [
    "nextjs",
    "react",
    "debugging",
    "devtools",
    "performance",
    "monitoring",
    "debugbar",
    "developer-tools",
    "frontend",
    "codenrs",
    "devlens",
    "nrshagor"
  ],
  "scripts": {
    "dev": "tsup src/index.tsx --watch",
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --external react-dom --external next",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint next\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codenrs/devlens-react": "0.1.0-alpha.3",
    "@codenrs/devlens-ui": "0.1.0-alpha.3",
    "@codenrs/devlens-core": "0.1.0-alpha.3"
  }
}
